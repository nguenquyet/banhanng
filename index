function doGet(e) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('SanPham');
  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  const result = data.slice(1).map(row => {
    let obj = {};
    headers.forEach((h, i) => obj[h] = row[i]);
    return obj;
  });
  const dhSheet = ss.getSheetByName('DonHang');
  const dhData = dhSheet.getDataRange().getValues();
  const dhHeaders = dhData[0];
  const dhResult = dhData.slice(1).map(row => {
    let obj = {};
    dhHeaders.forEach((h, i) => obj[h] = row[i]);
    return obj;
  });
  return ContentService.createTextOutput(JSON.stringify({sanPham: result, donHang: dhResult})).setMimeType(ContentService.MimeType.JSON);
}

function doPost(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('DonHang');
  const data = JSON.parse(e.postData.contents);
  sheet.appendRow([new Date(), data.tenKH, data.sdt, data.diaChi, data.tenSP, data.gia, data.ghiChu, 'Mới']);
  return ContentService.createTextOutput(JSON.stringify({status: 'ok'})).setMimeType(ContentService.MimeType.JSON);
}
